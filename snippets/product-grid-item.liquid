{% comment %}
Arguments
- product: product object
- [per_row]: number of items per row
- [quick_shop_enable]: boolean
- [collection]: collection object
{% endcomment %}

{%- liquid
  unless per_row
    assign per_row = 4
  endunless

  capture gridView
    render 'products_per_row', products_per_row: per_row, style: 'fractions'
  endcapture

  # These assignments have no effect if a sizes parameter is passed in
  assign sizeVariable = gridView
  if fallback != blank
    assign fallback = fallback
  else
    assign fallback = 'variable'
  endif

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign product_tags = product.tags | join: ','
  assign has_custom_label = false
  if product.metafields.theme.label and product.metafields.theme.label != blank
    assign has_custom_label = true
    assign custom_label = product.metafields.theme.label.value
  elsif product_tags contains '_label_'
    for tag in product.tags
      if tag contains '_label_'
        assign tag_starts_with = tag | slice: 0
        if tag_starts_with == '_'
          assign has_custom_label = true
          assign custom_label = tag | replace: '_label_', ''
        endif
      endif
    endfor
  endif
-%}

<div class="grid__item grid-product product-card {{ gridView }} {% if quick_shop_enable %} grid-product__has-quick-shop{% endif %}" data-product-handle="{{ product.handle }}" data-product-id="{{ product.id }}">
  <div class="grid-product__content">
    {%- if has_custom_label -%}
      <div class="grid-product__tag grid-product__tag--custom">
        {{ custom_label }}
      </div>
    {%- else -%}
      {%- unless product.available -%}
        <div class="grid-product__tag grid-product__tag--sold-out">
          {{ 'products.product.sold_out' | t }}
        </div>
      {%- endunless -%}
      {%- if on_sale and product.available -%}
        <div class="grid-product__tag grid-product__tag--sale">
          {{ 'products.general.sale' | t }}
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- liquid
      assign imageRatio = settings.product_grid_image_size
      assign fixed_aspect_ratio = false
      unless imageRatio == 'natural'
        assign fixed_aspect_ratio = true
      endunless

      if image_style == 'circle'
        assign fixed_aspect_ratio = true
        assign imageRatio = 'square'
      endif

      # Prioritize selected variant media if available
      assign main_media = product.featured_media
      
      if is_ajax
          if product.selected_or_first_available_variant.featured_media
             assign main_media = product.selected_or_first_available_variant.featured_media
          elsif product.selected_or_first_available_variant
             # If selected variant has no specific media assigned, try to find one in the gallery
             assign v_id = product.selected_or_first_available_variant.id
             for media in product.media
                if media.variants.size > 0
                    for v in media.variants
                        if v.id == v_id
                            assign main_media = media
                            break
                        endif
                    endfor
                endif
                if main_media.id != product.featured_media.id
                    break
                endif
             endfor
          endif
      endif
      
      assign preview_image = main_media.preview_image
    -%}

    <div class="grid__item-image-wrapper" data-original="{{ preview_image | img_url: '600x' }}">
      <div class="grid-product__image-mask">
  <!-- mobile carousel styles moved to theme.css -->
<div class="mobile-carousel" data-carousel>
    <div class="mobile-carousel-track" style="display:flex;">
      <div class="mobile-slide">
        {%- if fixed_aspect_ratio -%}
          <div class="grid__image-ratio grid__image-ratio--{% if image_style == 'circle' %}square{% else %}{{ settings.product_grid_image_size }}{% endif %}">
            {%- capture image_classes -%}
              product-image {% unless settings.product_grid_image_fill %} grid__image-contain{% endunless %} image-style--{{ image_style }}
            {%- endcapture -%}
            {%- render 'image-element',
              img: preview_image,
              classes: image_classes,
              sizes: sizes,
              sizeVariable: sizeVariable,
              fallback: fallback,
              widths: '360, 540, 720, 900, 1080',
              animation: 'none'
            -%}
          </div>
        {%- else -%}
          <div class="image-wrap" style="height:0;padding-bottom:{{ 100 | divided_by: preview_image.aspect_ratio }}%;">
            {%- render 'image-element',
              img: preview_image,
              classes: 'grid-product__image product-image',
              sizes: sizes,
              sizeVariable: sizeVariable,
              fallback: fallback,
              widths: '360, 540, 720, 900, 1080',
              animation: 'none'
            -%}
          </div>
        {%- endif -%}
      </div>
      {%- if settings.product_hover_image and product.media.size > 1 -%}
        {%- assign second_image = product.media[1].preview_image -%}
        {%- if second_image != blank -%}
          <div class="mobile-slide">
            {%- render 'image-element',
              img: second_image,
              classes: 'product-image',
              sizes: sizes,
              sizeVariable: sizeVariable,
              fallback: fallback,
              widths: '360, 540, 720, 1000',
              loading: 'eager',
              animation: 'none'
            -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
    <div class="mobile-dots">
  {%- assign slide_count = 1 -%}
  {%- if settings.product_hover_image and product.media.size > 1 -%}
    {%- assign slide_count = 2 -%}
  {%- endif -%}

  {%- for i in (1..slide_count) -%}
    <span class="dot {% if forloop.first %}active{% endif %}"></span>
  {%- endfor -%}
</div>
  </div>
  <div class="desktop-carousel">
    {%- if fixed_aspect_ratio -%}
      <div class="grid__image-ratio grid__image-ratio--{% if image_style == 'circle' %}square{% else %}{{ settings.product_grid_image_size }}{% endif %}">
        {%- capture image_classes -%}
          product-image {% unless settings.product_grid_image_fill %} grid__image-contain{% endunless %} image-style--{{ image_style }}
        {%- endcapture -%}
        {%- render 'image-element',
          img: preview_image,
          classes: image_classes,
          sizes: sizes,
          sizeVariable: sizeVariable,
          fallback: fallback,
          widths: '360, 540, 720, 900, 1080',
          animation: 'none'
        -%}
      </div>
    {%- else -%}
      <div class="image-wrap" style="height:0;padding-bottom:{{ 100 | divided_by: preview_image.aspect_ratio }}%;">
        {%- render 'image-element',
          img: preview_image,
          classes: 'grid-product__image product-image',
          sizes: sizes,
          sizeVariable: sizeVariable,
          fallback: fallback,
          widths: '360, 540, 720, 900, 1080',
          animation: 'none'
        -%}
      </div>
    {%- endif -%}
  </div>
 
</div>

      <a href="{{ product.url | within: collection }}" class="grid-product__link">
        <div class="grid-product__meta">
          <div class="grid-product__title grid-product__title--{{ settings.type_product_style }}">{{ product.title }}</div>
          {%- if settings.vendor_enable -%}
            <div class="grid-product__vendor">{{ product.vendor }}</div>
          {%- endif -%}
          <div class="grid-product__price">
            {%- if on_sale -%}
              <span class="visually-hidden">{{ 'products.general.regular_price' | t }}</span>
              <span class="grid-product__price--original">{{ product.compare_at_price | money }}</span>
              <span class="visually-hidden">{{ 'products.general.sale_price' | t }}</span>
            {%- endif -%}
            {%- if product.price_varies -%}
              {%- assign price = product.price_min | money -%}
              {{ 'products.general.from_text_html' | t: price: price }}
            {%- else -%}
              {{ product.price | money }}
            {%- endif -%}
            {%- if on_sale -%}
              {%- if settings.product_save_amount -%}
                {%- if settings.product_save_type == 'dollar' -%}
                  {%- capture saved_amount -%}{{ product.compare_at_price | minus: product.price | money }}{%- endcapture -%}
                {%- else -%}
                  {%- capture saved_amount -%}{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}%{%- endcapture -%}
                {%- endif -%}
                <span class="grid-product__price--savings">
                  {{ 'products.general.save_html' | t: saved_amount: saved_amount }}
                </span>
              {%- endif -%}
            {%- endif -%}

            {%- assign product_variant = product.selected_or_first_available_variant -%}
            {%- if product_variant.unit_price_measurement -%}
              <div class="product__unit-price">
                {%- capture unit_price_base_unit -%}
                  {%- if product_variant.unit_price_measurement -%}
                    {%- if product_variant.unit_price_measurement.reference_value != 1 -%}
                      {{ product_variant.unit_price_measurement.reference_value }}
                    {%- endif -%}
                    {{ product_variant.unit_price_measurement.reference_unit }}
                  {%- endif -%}
                {%- endcapture -%}

                {{ product_variant.unit_price | money }}/{{ unit_price_base_unit }}
              </div>
            {%- endif -%}
          </div>

          {%- if settings.enable_swatches and type == 'horizontal' -%}
            {%- liquid
              assign swatch_trigger = 'products.general.color_swatch_trigger' | t | downcase
              assign swatch_file_extension = 'png'
              assign color_count = 0
            -%}
        
            {% comment %} Check for sibling metafield first {% endcomment %}
            {%- if product.metafields.custom.color_siblings.value != blank -%}
              <div class="grid-product__colors grid-product__colors--{{ product.id }}" style="{{ swatch_style_inline }}">
                {%- for sibling in product.metafields.custom.color_siblings.value -%}
                  {%- liquid
                    assign color_name = ''
                    for option in sibling.options_with_values
                      assign option_down = option.name | downcase
                      if option_down contains 'color' or option_down contains 'colour'
                        assign color_name = option.values[0]
                        break
                      endif
                    endfor
        
                    assign color_file_name = color_name | handle | append: '.' | append: swatch_file_extension
                    assign color_image = color_file_name | file_img_url: '50x50' | prepend: 'https:' | split: '?' | first
                    assign color_swatch_fallback = color_name | split: ' ' | last | handle
                    assign color_count = color_count | plus: 1
                    
                    assign sibling_image_url = sibling.featured_media.preview_image | img_url: '600x'

                    assign sibling_color_data = blank
            
                    if sibling.metafields.custom.color_swatch.value != blank
                       assign sibling_color_data = sibling.metafields.custom.color_swatch.value
                    elsif sibling.metafields.shopify['color-pattern'].value != blank
                       assign sibling_color_data = sibling.metafields.shopify['color-pattern'].value
                    elsif sibling.metafields.custom.color_pattern.value != blank
                       assign sibling_color_data = sibling.metafields.custom.color_pattern.value
                    elsif sibling.metafields.custom.color.value != blank
                       assign sibling_color_data = sibling.metafields.custom.color.value
                    endif

                    assign bg_style = ''
                    
                    if sibling_color_data != blank
                      if sibling_color_data.color != blank
                         assign bg_style = 'background-color: ' | append: sibling_color_data.color | append: ';'
                      elsif sibling_color_data.image != blank
                         assign bg_img = sibling_color_data.image | img_url: '100x'
                         assign bg_style = 'background-image: url(' | append: bg_img | append: '); background-color: transparent;'
                      elsif sibling_color_data contains '#' or sibling_color_data contains 'rgb' or sibling_color_data contains 'hsl'
                        assign bg_style = 'background-color: ' | append: sibling_color_data | append: ';'
                      else
                         assign bg_img = sibling_color_data | img_url: '100x'
                         if bg_img
                            assign bg_style = 'background-image: url(' | append: bg_img | append: '); background-color: transparent;'
                         endif
                      endif
                    endif

                    if bg_style == ''
                         assign bg_style = 'background-color: ' | append: color_swatch_fallback | append: ';'
                         if images[color_file_name] != blank
                            assign bg_img = color_image
                            assign bg_style = 'background-image: url(' | append: bg_img | append: ');'
                         endif
                    endif
                  -%}
        
                  <div 
                    class="color-swatch color-swatch--small color-swatch--{{ color_name | handle }} sibling-swatch swatch"
                    data-sibling-url="{{ sibling.url | within: collection }}"
                    data-image="{{ sibling.featured_media.preview_image | img_url: '600x' }}"
                    data-sibling-image="{{ sibling_image_url }}"
                    aria-label="{{ sibling.title }} - {{ color_name }}"
                    style="{{ bg_style }}">
                  </div>
                {%- endfor -%}
              </div>

            {%- else -%}
        
            {%- for option in product.options_with_values -%}
              {%- liquid
                assign option_name = option.name | downcase
                assign is_color = false
                if option_name contains swatch_trigger
                  assign is_color = true
                elsif swatch_trigger == 'color' and option_name contains 'colour'
                  assign is_color = true
                endif
              -%}
              {%- if is_color -%}
                {%- assign option_index = forloop.index0 -%}
                {%- assign values = '' -%}
                <div class="grid-product__colors grid-product__colors--{{ product.id }}" style="{{ swatch_style_inline }}">
                  {%- for variant in product.variants -%}
                    {%- assign value = variant.options[option_index] %}
                    {%- unless values contains value -%}
                      {%- liquid
                        assign values = values | join: ',' | append: ',' | append: value | split: ','

                        assign color_file_name = value | handle | append: '.' | append: swatch_file_extension
                        assign color_image = color_file_name | file_img_url: '50x50' | prepend: 'https:' | split: '?' | first
                        assign color_swatch_fallback = value | split: ' ' | last | handle
                        assign color_count = color_count | plus: 1
                      -%}

                      <span
                        class="color-swatch color-swatch--small swatch color-swatch--{{ value | handle }}{% if variant.image %} color-swatch--with-image{% endif %}"
                        {% if variant.image %}
                          data-variant-id="{{ variant.id }}"
                          data-image="{{ variant.image | img_url: '600x' }}"
                          data-variant-image="{{ variant.image | img_url: '400x' }}"
                        {% endif %}
                        aria-label="{{ product.title }} - {{ value }}"
                        style="background-color: {{ color_swatch_fallback }};{% if images[color_file_name] != blank %}  background-image: url({{ color_image }});{% endif %}">
                        <span class="visually-hidden">{{ value }}</span>
                      </span>
                    {%- endunless -%}
                  {%- endfor -%}
                </div>
                {%- if color_count < 2 -%}
                  {%- style -%}
                    .grid-product__colors--{{ product.id }} {
                      display: none;
                    }
                  {%- endstyle -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
        </div>
      </a>
    </div>
  </div>
      {%- if settings.enable_swatches and type == blank and show_bottom_swatches -%}
        {%- liquid
      assign swatch_trigger = 'products.general.color_swatch_trigger' | t | downcase
      assign swatch_file_extension = 'png'
      assign color_count = 0
    -%}

    {% comment %} Check for sibling metafield first {% endcomment %}
    {%- if product.metafields.custom.color_siblings.value != blank -%}
      <div class="grid-product__colors grid-product__colors--{{ product.id }}">
        
        {%- assign siblings_sorted = product.metafields.custom.color_siblings.value | sort: 'title' -%}
        {%- assign sibling_count = siblings_sorted.size -%}
        {%- assign loop_limit = sibling_count -%}
        
        {%- if limit_swatches -%}
          {%- assign loop_limit = 5 -%}
        {%- endif -%}

        {%- for sibling in siblings_sorted limit: loop_limit -%}
          {%- comment -%}
            New Sibling Logic: Check custom.color which is a List of Metaobjects
          {%- endcomment -%}
          {%- assign sibling_colors = sibling.metafields.custom.color.value -%}
          
          {%- assign sold_out_class = '' -%}
          {%- if show_out_of_stock_swatches and sibling.available == false -%}
            {%- assign sold_out_class = 'color-swatch--sold-out' -%}
          {%- endif -%}

          {%- assign active_class = '' -%}
          {%- if sibling.handle == product.handle -%}
            {%- assign active_class = 'is-active' -%}
          {%- endif -%}
          
          {%- if sibling_colors != blank -%}
            {%- for color_metaobject in sibling_colors -%}
               {%- liquid
                 assign bg_style = ''
                 if color_metaobject.color != blank
                     assign bg_style = 'background-color: ' | append: color_metaobject.color | append: ';'
                 else
                    assign bg_img = sibling.featured_media.preview_image | img_url: '100x'
                    assign bg_style = 'background-image: url(' | append: bg_img | append: '); background-color: transparent;'
                 endif
                 
                 assign color_count = color_count | plus: 1
                 assign sibling_image_url = sibling.featured_media.preview_image | img_url: '600x'
                 
                 comment
                    Get the hovered/second image from the sibling product
                 endcomment
                 assign sibling_hover_image_url = sibling.media[1].preview_image | img_url: '600x'
                 
                 assign color_name = color_metaobject.name | default: sibling.title
               -%}
               <a href="{{ sibling.url | within: collection }}" 
                  class="color-swatch color-swatch--small sibling-swatch swatch {{ sold_out_class }} {{ active_class }}"
                  data-sibling-url="{{ sibling.url | within: collection }}"
                  data-image="{{ sibling_image_url }}"
                  data-sibling-image="{{ sibling_image_url }}"
                  data-sibling-hover-image="{{ sibling_hover_image_url }}"
                  aria-label="{{ sibling.title }} - {{ color_name }}"
                  style="{{ bg_style }}">
               </a>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%}
              Fallback if no colors data found: Use product image
            {%- endcomment -%}
             {%- liquid
               assign bg_img = sibling.featured_media.preview_image | img_url: '100x'
               assign bg_style = 'background-image: url(' | append: bg_img | append: '); background-color: transparent;'
               assign sibling_image_url = sibling.featured_media.preview_image | img_url: '600x'
               
               comment
                  Get the hovered/second image from the sibling product
               endcomment
               assign sibling_hover_image_url = sibling.media[1].preview_image | img_url: '600x'
               
               assign color_count = color_count | plus: 1
             -%}
             <a href="{{ sibling.url | within: collection }}"
                class="color-swatch color-swatch--small sibling-swatch swatch {{ sold_out_class }} {{ active_class }}"
                data-sibling-url="{{ sibling.url | within: collection }}"
                data-image="{{ sibling_image_url }}"
                data-sibling-image="{{ sibling_image_url }}"
                data-sibling-hover-image="{{ sibling_hover_image_url }}"
                aria-label="{{ sibling.title }}"
                style="{{ bg_style }}">
             </a>
          {%- endif -%}
        {%- endfor -%}

        {%- if limit_swatches and sibling_count > 5 -%}
          <a href="{{ product.url | within: collection }}" class="color-swatch__more-link" style="font-size: 11px; line-height: 15px; vertical-align: top; display: inline-block; margin-left: 2px; color: var(--colorTextBody);">
            +{{ sibling_count | minus: 5 }}
          </a>
        {%- endif -%}
      </div>

    {%- else -%}

      {%- for option in product.options_with_values -%}
        {%- liquid
          assign option_name = option.name | downcase
          assign is_color = false
          if option_name contains swatch_trigger
            assign is_color = true
          elsif swatch_trigger == 'color' and option_name contains 'colour'
            assign is_color = true
          endif
        -%}
        {%- if is_color -%}
          {%- assign option_index = forloop.index0 -%}
          {%- assign values = '' -%}
          <div class="grid-product__colors grid-product__colors--{{ product.id }}">
            {%- for variant in product.variants -%}
              {%- assign value = variant.options[option_index] %}
              {%- unless values contains value -%}
                {%- liquid
                  assign values = values | join: ',' | append: ',' | append: value | split: ','

                  assign color_file_name = value | handle | append: '.' | append: swatch_file_extension
                  assign color_image = color_file_name | file_img_url: '50x50' | prepend: 'https:' | split: '?' | first
                  assign color_swatch_fallback = value | split: ' ' | last | handle
                  assign color_count = color_count | plus: 1
                  
                  assign variant_meta_color = variant.metafields.custom.color_swatch.value
                  assign variant_shopify_color = variant.metafields.shopify['color-pattern'].value

                  assign bg_style = ''
            
                  if variant_shopify_color != blank
                    if variant_shopify_color.color != blank
                      assign bg_style = 'background-color: ' | append: variant_shopify_color.color | append: ';'
                    elsif variant_shopify_color.image != blank
                      assign bg_img = variant_shopify_color.image | img_url: '100x'
                      assign bg_style = 'background-image: url(' | append: bg_img | append: '); background-color: transparent;'
                    elsif variant_shopify_color contains '#'
                      assign bg_style = 'background-color: ' | append: variant_shopify_color | append: ';'
                    endif
                  endif
                  
                  if bg_style == '' and variant_meta_color != blank
                    if variant_meta_color contains '#'
                        assign bg_style = 'background-color: ' | append: variant_meta_color | append: ';'
                    else
                        assign bg_img = variant_meta_color | img_url: '100x'
                        if bg_img == blank
                           assign bg_img = variant_meta_color
                        endif
                        assign bg_style = 'background-image: url(' | append: bg_img | append: '); background-color: transparent;'
                    endif
                  endif
                  
                  if bg_style == ''
                    assign bg_style = 'background-color: ' | append: color_swatch_fallback | append: ';'
                    if images[color_file_name] != blank
                        assign bg_img = color_image
                        assign bg_style = 'background-image: url(' | append: bg_img | append: ');'
                    elsif variant.image != blank
                        assign bg_img = variant.image | img_url: '100x', crop: 'center'
                        assign bg_style = 'background-image: url(' | append: bg_img | append: ');'
                    endif
                  endif
                  assign sold_out_class = ''
                  if show_out_of_stock_swatches and variant.available == false
                    assign sold_out_class = 'color-swatch--sold-out'
                  endif
                  
                  assign active_class = ''
                  if product.selected_variant
                    if variant.id == product.selected_variant.id
                       assign active_class = 'is-active'
                    endif
                  else
                    if forloop.first
                       assign active_class = 'is-active'
                    endif
                  endif
                  
                  assign sibling_hover_image_url = ''
                  if variant.featured_media
                     assign pos = variant.featured_media.position
                     assign next_idx = pos
                     if product.media[next_idx]
                        assign sibling_hover_image_url = product.media[next_idx].preview_image | img_url: '600x'
                     endif
                  endif
                  
                  if sibling_hover_image_url == blank and product.media[1]
                     assign sibling_hover_image_url = product.media[1].preview_image | img_url: '600x'
                  endif
                -%}

                <a
                  href="{{ variant.url | within: collection }}"
                  class="sibling-swatch color-swatch color-swatch--small color-swatch--{{ value | handle }} {{ sold_out_class }} {{ active_class }}"
                  data-sibling-url="{{ variant.url | within: collection }}"
                  data-sibling-image="{{ variant.image | img_url: '600x' }}"
                  data-sibling-hover-image="{{ sibling_hover_image_url }}"
                  aria-label="{{ product.title }} - {{ value }}"
                  style="{{ bg_style }}">
                  <span class="visually-hidden">{{ value }}</span>
                </a>
              {%- endunless -%}
            {%- endfor -%}
          </div>
          {%- if color_count < 2 -%}
            {%- style -%}
              .grid-product__colors--{{ product.id }} {
                display: none;
              }
            {%- endstyle -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

    {%- endif -%}
  {%- endif -%}

  {%- if quick_shop_enable and type == blank -%}
    {%- render 'quick-shop-modal', product: product -%}
  {%- endif -%}
</div>
