{%- if cart.item_count > 0 -%}
  {%- assign cart_handles = ',' -%}
  {%- for item in cart.items -%}
    {%- assign cart_handles = cart_handles | append: item.product.handle | append: ',' -%}
  {%- endfor -%}

  {%- assign top_type = '' -%}
  {%- assign top_type_count = 0 -%}
  {%- assign type_bucket = '' -%}

  {%- for item in cart.items -%}
    {%- assign item_type = item.product.type | strip -%}
    {%- if item_type != blank -%}
      {%- assign type_bucket = type_bucket | append: item_type | append: '||' -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign type_list = type_bucket | split: '||' -%}
  {%- for category in type_list -%}
    {%- assign category = category | strip -%}
    {%- if category != blank -%}
      {%- assign category_count = 0 -%}
      {%- for compare_category in type_list -%}
        {%- if compare_category == category -%}
          {%- assign category_count = category_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if category_count > top_type_count -%}
        {%- assign top_type_count = category_count -%}
        {%- assign top_type = category -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if top_type == blank and cart.items.first != blank -%}
    {%- assign top_type = cart.items.first.product.type | strip -%}
  {%- endif -%}

  {%- assign primary_collection_handle = '' -%}
  {%- for item in cart.items -%}
    {%- for collection in item.product.collections -%}
      {%- if collection.handle != 'all' and collection.products_count > 1 -%}
        {%- assign primary_collection_handle = collection.handle -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if primary_collection_handle != blank -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign picked_handles = ',' -%}
  {%- assign same_collection_product = blank -%}
  {%- assign same_category_product = blank -%}
  {%- assign random_product = blank -%}

  {%- if primary_collection_handle != blank and collections[primary_collection_handle] != blank -%}
    {%- for product in collections[primary_collection_handle].products limit: 50 -%}
      {%- assign product_token = ',' | append: product.handle | append: ',' -%}
      {%- unless cart_handles contains product_token or picked_handles contains product_token or product.available == false -%}
        {%- assign same_collection_product = product -%}
        {%- assign picked_handles = picked_handles | append: product.handle | append: ',' -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if top_type != blank -%}
    {%- for product in collections.all.products limit: 120 -%}
      {%- assign product_token = ',' | append: product.handle | append: ',' -%}
      {%- if product.type == top_type -%}
        {%- unless cart_handles contains product_token or picked_handles contains product_token or product.available == false -%}
          {%- assign same_category_product = product -%}
          {%- assign picked_handles = picked_handles | append: product.handle | append: ',' -%}
          {%- break -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- assign random_offset = 'now' | date: '%S' | plus: cart.item_count -%}
  {%- for product in collections.all.products offset: random_offset limit: 120 -%}
    {%- assign product_token = ',' | append: product.handle | append: ',' -%}
    {%- unless cart_handles contains product_token or picked_handles contains product_token or product.available == false -%}
      {%- assign random_product = product -%}
      {%- assign picked_handles = picked_handles | append: product.handle | append: ',' -%}
      {%- break -%}
    {%- endunless -%}
  {%- endfor -%}

  {%- if same_collection_product == blank -%}
    {%- for product in collections.all.products limit: 120 -%}
      {%- assign product_token = ',' | append: product.handle | append: ',' -%}
      {%- unless cart_handles contains product_token or picked_handles contains product_token or product.available == false -%}
        {%- assign same_collection_product = product -%}
        {%- assign picked_handles = picked_handles | append: product.handle | append: ',' -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if same_category_product == blank -%}
    {%- for product in collections.all.products limit: 120 -%}
      {%- assign product_token = ',' | append: product.handle | append: ',' -%}
      {%- unless cart_handles contains product_token or picked_handles contains product_token or product.available == false -%}
        {%- assign same_category_product = product -%}
        {%- assign picked_handles = picked_handles | append: product.handle | append: ',' -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if random_product == blank -%}
    {%- for product in collections.all.products limit: 120 -%}
      {%- assign product_token = ',' | append: product.handle | append: ',' -%}
      {%- unless cart_handles contains product_token or picked_handles contains product_token or product.available == false -%}
        {%- assign random_product = product -%}
        {%- break -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}

  {%- assign upsell_count = 0 -%}
  {%- if same_collection_product != blank -%}{%- assign upsell_count = upsell_count | plus: 1 -%}{%- endif -%}
  {%- if same_category_product != blank -%}{%- assign upsell_count = upsell_count | plus: 1 -%}{%- endif -%}
  {%- if random_product != blank -%}{%- assign upsell_count = upsell_count | plus: 1 -%}{%- endif -%}

  {%- if upsell_count > 0 -%}
    <div class="cart-drawer-upsell" data-cart-upsell-section>
      <div class="cart-drawer-upsell__header">You may also like</div>
      <div class="cart-drawer-upsell__carousel" data-upsell-carousel>
        <button type="button" class="cart-drawer-upsell__nav cart-drawer-upsell__nav--prev" data-upsell-prev aria-label="Previous recommendation">
          <span aria-hidden="true">&lsaquo;</span>
        </button>
        <div class="cart-drawer-upsell__viewport" data-upsell-viewport>
          <div class="cart-drawer-upsell__track" data-upsell-track>
          {%- if same_collection_product != blank -%}
            <div class="cart-drawer-upsell__slide">
              <article class="cart-drawer-upsell__card">
                <a href="{{ same_collection_product.url }}" class="cart-drawer-upsell__image-link" aria-label="{{ same_collection_product.title | escape }}">
                  {%- if same_collection_product.featured_image != blank -%}
                    {{ same_collection_product.featured_image | image_url: width: 360 | image_tag: class: 'cart-drawer-upsell__image', widths: '180,240,360', sizes: '180px', loading: 'lazy', alt: same_collection_product.title }}
                  {%- endif -%}
                </a>
                <div class="cart-drawer-upsell__meta">
                  <a href="{{ same_collection_product.url }}" class="cart-drawer-upsell__name">{{ same_collection_product.title }}</a>
                  <div class="cart-drawer-upsell__price">{{ same_collection_product.price | money }}</div>
                  <form action="{{ routes.cart_add_url }}" method="post" class="cart-drawer-upsell__form" enctype="multipart/form-data">
                    {%- if same_collection_product.has_only_default_variant == false -%}
                      <label class="visually-hidden" for="UpsellVariant-{{ same_collection_product.id }}">Choose variant</label>
                      <select id="UpsellVariant-{{ same_collection_product.id }}" name="id" class="cart-drawer-upsell__variant" required>
                        {%- for variant in same_collection_product.variants -%}
                          <option value="{{ variant.id }}"{% if variant == same_collection_product.selected_or_first_available_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
                            {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                          </option>
                        {%- endfor -%}
                      </select>
                    {%- else -%}
                      <input type="hidden" name="id" value="{{ same_collection_product.selected_or_first_available_variant.id }}">
                    {%- endif -%}
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="btn cart-drawer-upsell__add"{% if same_collection_product.available == false %} disabled{% endif %}>
                      {%- if same_collection_product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
                    </button>
                  </form>
                </div>
              </article>
            </div>
          {%- endif -%}

          {%- if same_category_product != blank -%}
            <div class="cart-drawer-upsell__slide">
              <article class="cart-drawer-upsell__card">
                <a href="{{ same_category_product.url }}" class="cart-drawer-upsell__image-link" aria-label="{{ same_category_product.title | escape }}">
                  {%- if same_category_product.featured_image != blank -%}
                    {{ same_category_product.featured_image | image_url: width: 360 | image_tag: class: 'cart-drawer-upsell__image', widths: '180,240,360', sizes: '180px', loading: 'lazy', alt: same_category_product.title }}
                  {%- endif -%}
                </a>
                <div class="cart-drawer-upsell__meta">
                  <a href="{{ same_category_product.url }}" class="cart-drawer-upsell__name">{{ same_category_product.title }}</a>
                  <div class="cart-drawer-upsell__price">{{ same_category_product.price | money }}</div>
                  <form action="{{ routes.cart_add_url }}" method="post" class="cart-drawer-upsell__form" enctype="multipart/form-data">
                    {%- if same_category_product.has_only_default_variant == false -%}
                      <label class="visually-hidden" for="UpsellVariant-{{ same_category_product.id }}">Choose variant</label>
                      <select id="UpsellVariant-{{ same_category_product.id }}" name="id" class="cart-drawer-upsell__variant" required>
                        {%- for variant in same_category_product.variants -%}
                          <option value="{{ variant.id }}"{% if variant == same_category_product.selected_or_first_available_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
                            {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                          </option>
                        {%- endfor -%}
                      </select>
                    {%- else -%}
                      <input type="hidden" name="id" value="{{ same_category_product.selected_or_first_available_variant.id }}">
                    {%- endif -%}
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="btn cart-drawer-upsell__add"{% if same_category_product.available == false %} disabled{% endif %}>
                      {%- if same_category_product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
                    </button>
                  </form>
                </div>
              </article>
            </div>
          {%- endif -%}

          {%- if random_product != blank -%}
            <div class="cart-drawer-upsell__slide">
              <article class="cart-drawer-upsell__card">
                <a href="{{ random_product.url }}" class="cart-drawer-upsell__image-link" aria-label="{{ random_product.title | escape }}">
                  {%- if random_product.featured_image != blank -%}
                    {{ random_product.featured_image | image_url: width: 360 | image_tag: class: 'cart-drawer-upsell__image', widths: '180,240,360', sizes: '180px', loading: 'lazy', alt: random_product.title }}
                  {%- endif -%}
                </a>
                <div class="cart-drawer-upsell__meta">
                  <a href="{{ random_product.url }}" class="cart-drawer-upsell__name">{{ random_product.title }}</a>
                  <div class="cart-drawer-upsell__price">{{ random_product.price | money }}</div>
                  <form action="{{ routes.cart_add_url }}" method="post" class="cart-drawer-upsell__form" enctype="multipart/form-data">
                    {%- if random_product.has_only_default_variant == false -%}
                      <label class="visually-hidden" for="UpsellVariant-{{ random_product.id }}">Choose variant</label>
                      <select id="UpsellVariant-{{ random_product.id }}" name="id" class="cart-drawer-upsell__variant" required>
                        {%- for variant in random_product.variants -%}
                          <option value="{{ variant.id }}"{% if variant == random_product.selected_or_first_available_variant %} selected{% endif %}{% unless variant.available %} disabled{% endunless %}>
                            {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                          </option>
                        {%- endfor -%}
                      </select>
                    {%- else -%}
                      <input type="hidden" name="id" value="{{ random_product.selected_or_first_available_variant.id }}">
                    {%- endif -%}
                    <input type="hidden" name="quantity" value="1">
                    <button type="submit" class="btn cart-drawer-upsell__add"{% if random_product.available == false %} disabled{% endif %}>
                      {%- if random_product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
                    </button>
                  </form>
                </div>
              </article>
            </div>
          {%- endif -%}
          </div>
        </div>
        <button type="button" class="cart-drawer-upsell__nav cart-drawer-upsell__nav--next" data-upsell-next aria-label="Next recommendation">
          <span aria-hidden="true">&rsaquo;</span>
        </button>
      </div>
    </div>
  {%- endif -%}
{%- endif -%}
