{
  "type": "custom.popups",
  "name": "t:sections.popup-group.name",
  "sections": {
    "newsletter-popup": {
      "type": "newsletter-popup",
      "blocks": {
        "reminder-block": {
          "type": "header",
          "disabled": true,
          "settings": {
            "reminder_label": "Get 10% off"
          }
        }
      },
      "block_order": [
        "reminder-block"
      ],
      "disabled": true,
      "custom_css": [],
      "settings": {
        "disable_for_account_holders": false,
        "popup_seconds": 2,
        "popup_days": 1,
        "mobile_vertical_offset": 0,
        "popup_max_width": 320,
        "popup_max_height": 40,
        "popup_content_padding": 0,
        "popup_content_padding_mobile": 0,
        "popup_padding_top": 0,
        "popup_padding_bottom": 0,
        "popup_padding_top_mobile": 0,
        "popup_padding_bottom_mobile": 0,
        "popup_logo": "shopify://shop_images/HSW_LOGO_BLACK.png",
        "popup_logo_width": 70,
        "popup_font_family": "body",
        "popup_text_alignment": "center",
        "popup_title_size": 27,
        "popup_title_color": "#111111",
        "popup_text_size": 18,
        "popup_text_color": "#111111",
        "popup_title": "Extra 5% Off",
        "popup_text": "<p>When Paying With Card</p>",
        "show_social_icons": false,
        "enable_newsletter": false,
        "button_label": "",
        "button_link": "shopify://collections/all"
      }
    },
    "age-verification-popup": {
      "type": "age-verification-popup",
      "disabled": true,
      "settings": {
        "enable_test_mode": false,
        "blur_image": false,
        "heading": "Confirm your age",
        "text": "<p>Are you 18 years old or older?</p>",
        "decline_button_label": "No I'm not",
        "approve_button_label": "Yes I am",
        "decline_heading": "Come back when you're older",
        "decline_text": "<p>Sorry, the content of this store can't be seen by a younger audience. Come back when you're older.</p>",
        "return_button_label": "Oops, I entered incorrectly"
      }
    }
  },
  "order": [
    "newsletter-popup",
    "age-verification-popup"
  ]
}
