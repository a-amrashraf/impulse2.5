{%- assign gap_value = section.settings.gap_value -%}
{%- assign padding_top = section.settings.padding_top -%}
{%- assign padding_bottom = section.settings.padding_bottom -%}
{%- assign padding_h = section.settings.padding_horizontal -%}

{%- comment -%} Determine border radius based on settings {%- endcomment -%}
{%- assign border_radius = "0px" -%}
{%- if section.settings.image_shape == "circle" -%}
  {%- assign border_radius = "50%" -%}
{%- elsif section.settings.image_shape == "rounded" -%}
  {%- assign border_radius = "12px" -%}
{%- endif -%}

{%- comment -%} Determine dimensions {%- endcomment -%}
{%- assign base_size_d = section.settings.image_size_desktop | default: 70 -%}
{%- assign base_size_m = section.settings.image_size_mobile | default: 60 -%}
{%- assign image_ratio = "1/1" -%}

{%- if section.settings.image_ratio == "portrait" -%}
  {%- assign image_ratio = "3/4" -%}
  {%- assign image_width_desktop = base_size_d | append: "px" -%}
  {%- assign image_height_desktop = base_size_d | times: 1.33 | round | append: "px" -%}
  {%- assign image_width_mobile = base_size_m | append: "px" -%}
  {%- assign image_height_mobile = base_size_m | times: 1.33 | round | append: "px" -%}
{%- elsif section.settings.image_ratio == "landscape" -%}
  {%- assign image_ratio = "4/3" -%}
  {%- assign image_height_desktop = base_size_d | append: "px" -%}
  {%- assign image_width_desktop = base_size_d | times: 1.33 | round | append: "px" -%}
  {%- assign image_height_mobile = base_size_m | append: "px" -%}
  {%- assign image_width_mobile = base_size_m | times: 1.33 | round | append: "px" -%}
{%- else -%}
  {%- assign image_ratio = "1/1" -%}
  {%- assign image_width_desktop = base_size_d | append: "px" -%}
  {%- assign image_height_desktop = base_size_d | append: "px" -%}
  {%- assign image_width_mobile = base_size_m | append: "px" -%}
  {%- assign image_height_mobile = base_size_m | append: "px" -%}
{%- endif -%}

<div class="category-bar-wrapper" style="
  --gap: {{ gap_value }}px; 
  --padding-top: {{ padding_top }}px; 
  --padding-bottom: {{ padding_bottom }}px;
  --padding-h: {{ padding_h }}px;
  --border-radius: {{ border_radius }};
  --image-height-d: {{ image_height_desktop }};
  --image-width-d: {{ image_width_desktop }};
  --image-height-m: {{ image_height_mobile }};
  --image-width-m: {{ image_width_mobile }};
  --image-object-fit: {% if section.settings.image_shape == 'circle' %}cover{% else %}contain{% endif %};
">
  {% if section.settings.title != blank %}
  <div class="section-header text-center">
    <h2 class="section-header__title">{{ section.settings.title }}</h2>
  </div>
  {% endif %}

  <div class="category-bar">
    {% for block in section.blocks %}
      {%- assign collection = collections[block.settings.collection] -%}
      {%- assign item_image = block.settings.custom_image -%}
      {%- assign item_title = block.settings.custom_title -%}
      
      {%- if collection != blank or item_image != blank -%}
        <a href="{{ collection.url | default: '#' }}" class="category-item" {{ block.shopify_attributes }}>
          <div class="category-image-wrapper">
             {%- if item_image != blank -%}
               <img src="{{ item_image | img_url: '300x' }}" alt="{{ item_title | default: collection.title | escape }}" loading="lazy">
             {%- elsif collection.image -%}
               <img src="{{ collection.image | img_url: '300x' }}" alt="{{ collection.title | escape }}" loading="lazy">
             {%- elsif collection.products.first and collection.products.first.featured_image -%}
               <img src="{{ collection.products.first.featured_image | img_url: '300x' }}" alt="{{ collection.title | escape }}" loading="lazy">
             {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
             {%- endif -%}
          </div>
          <span class="category-title">{{ item_title | default: collection.title }}</span>
        </a>
      {%- endif -%}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Navigation",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Shop by Collection"
    },
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "Image Shape",
      "default": "square",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "rounded", "label": "Rounded Corners" },
        { "value": "circle", "label": "Circle" }
      ]
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Ratio",
      "default": "square",
      "info": "Controls the aspect ratio. Height/Width is calculated from the base size below.",
      "options": [
        { "value": "square", "label": "Normal (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ]
    },
    {
      "type": "range",
      "id": "image_size_desktop",
      "label": "Image Base Size (Desktop)",
      "default": 70,
      "min": 40,
      "max": 150,
      "step": 2,
      "unit": "px",
      "info": "Sets the width (for portrait) or height (for landscape/square)."
    },
    {
      "type": "range",
      "id": "image_size_mobile",
      "label": "Image Base Size (Mobile)",
      "default": 60,
      "min": 30,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "range",
      "id": "gap_value",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Space between items",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Optional)",
          "info": "Overrides the collection default image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Label (Optional)",
          "info": "Overrides the collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Navigation",
      "category": "Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
.category-bar-wrapper {
  width: 100%;
  box-sizing: border-box; /* Ensures padding is calculated with width */
  padding-left: var(--padding-h, 20px);
  padding-right: var(--padding-h, 20px);
  padding-top: var(--padding-top, 20px);
  padding-bottom: var(--padding-bottom, 20px);
}

.category-bar {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: var(--gap, 24px);
  padding: 0;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none; /* IE 10+ */
  justify-content: center; /* Keep items centered in the container */
  width: 100%;
}

/* Hide scrollbar for Chrome/Safari/Opera */
.category-bar::-webkit-scrollbar {
  display: none; 
}

/* Individual item styling */
.category-item {
  flex: 0 0 auto; /* Don't shrink/grow */
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  color: inherit;
  width: 100px; /* specific width ensures consistency */
  border-radius: 0;
  background: transparent;
  text-align: center;
  transition: opacity 0.2s ease;
}

.category-item:hover {
  opacity: 0.7;
}

/* Image wrapper to constrain size */
.category-image-wrapper {
  height: var(--image-height-d, 70px);
  width: var(--image-width-d, 70px);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  border-radius: var(--border-radius, 0px);
  overflow: hidden; /* Ensure image clips to border radius */
}

/* Ensure images maintain aspect ratio */
.category-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: var(--image-object-fit, contain); 
  display: block;
}

/* Text styling */
.category-title {
  font-size: 11px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-weight: 600;
  line-height: 1.3;
  color: #333; /* Dark text for contrast */
}

/* Placeholder styling */
.category-image-wrapper svg {
  width: 100%;
  height: 100%;
  fill: #e1e1e1;
}

/* Mobile optimizations */
@media screen and (max-width: 768px) {
  .category-bar-wrapper {
    padding-left: var(--padding-h, 16px);
    padding-right: var(--padding-h, 16px);
  }
  .category-bar {
    gap: var(--gap, 16px);
  }
  .category-item {
     width: 85px;
  }
  .category-image-wrapper {
    height: var(--image-height-m, 60px);
    width: var(--image-width-m, 60px);
    margin-bottom: 8px;
  }
  .category-title {
    font-size: 10px;
  }
}
{% endstylesheet %}