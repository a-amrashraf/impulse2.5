<div class="page-width">
  {% if section.settings.title != blank %}
    <div class="section-header text-center">
      <h2 class="section-header__title">{{ section.settings.title }}</h2>
    </div>
  {% endif %}

  <div class="category-bar">
    {% for block in section.blocks %}
      {%- assign collection = collections[block.settings.collection] -%}
      {%- if collection != blank -%}
        <a href="{{ collection.url }}" class="category-item" {{ block.shopify_attributes }}>
          <div class="category-image-wrapper">
             {%- if collection.image -%}
               <img src="{{ collection.image | img_url: '300x' }}" alt="{{ collection.title | escape }}" loading="lazy">
             {%- elsif collection.products.first and collection.products.first.featured_image -%}
               <img src="{{ collection.products.first.featured_image | img_url: '300x' }}" alt="{{ collection.title | escape }}" loading="lazy">
             {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
             {%- endif -%}
          </div>
          <span class="category-title">{{ collection.title }}</span>
        </a>
      {%- endif -%}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Navigation",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Shop by Collection"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Navigation",
      "category": "Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}
/* Main container for the category bar */
.category-bar {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 24px;
  padding: 20px 0;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none; /* IE 10+ */
  justify-content: flex-start; /* Default align left for scrolling */
}

/* Center on desktop if content fits */
@media screen and (min-width: 769px) {
  .category-bar {
    justify-content: center;
  }
}

/* Hide scrollbar for Chrome/Safari/Opera */
.category-bar::-webkit-scrollbar {
  display: none; 
}

/* Individual item styling */
.category-item {
  flex: 0 0 auto; /* Don't shrink/grow */
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  color: inherit;
  width: 100px; /* specific width ensures consistency */
  border-radius: 0;
  background: transparent;
  text-align: center;
  transition: opacity 0.2s ease;
}

.category-item:hover {
  opacity: 0.7;
}

/* Image wrapper to constrain size */
.category-image-wrapper {
  height: 70px; /* Approx 60-80px as requested */
  width: 70px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

/* Ensure images maintain aspect ratio */
.category-image-wrapper img {
  max-height: 100%;
  max-width: 100%;
  width: auto;
  height: auto;
  object-fit: contain; 
  display: block;
}

/* Text styling */
.category-title {
  font-size: 11px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-weight: 600;
  line-height: 1.3;
  color: #333; /* Dark text for contrast */
}

/* Placeholder styling */
.category-image-wrapper svg {
  width: 100%;
  height: 100%;
  fill: #e1e1e1;
}

/* Mobile optimizations */
@media screen and (max-width: 768px) {
  .category-bar {
    padding-left: 16px;
    padding-right: 16px;
    gap: 16px;
  }
  .category-item {
     width: 85px;
  }
  .category-image-wrapper {
    height: 60px;
    width: 60px;
    margin-bottom: 8px;
  }
  .category-title {
    font-size: 10px;
  }
}
{% endstylesheet %}